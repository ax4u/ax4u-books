# =============================================================================
# AX4U Books — environment variables
# Copy to .env.local and fill in. Any service left blank runs in MOCK mode so
# the app still works end-to-end locally. See SETUP.md for details.
# =============================================================================

# App base URL (used for checkout success + webhook redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Supabase (auth + database). Blank => mock cookie auth + in-memory store.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — server only, REQUIRED for the Polar webhook to write books.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Polar (one-time payment per book). Blank => instant mock checkout.
# For local webhook testing with `npm run polar:listen`, copy the printed
# "Secret" value into POLAR_WEBHOOK_SECRET. Multiple accepted secrets can be
# comma-separated, e.g. dashboard_secret,cli_listen_secret.
# -----------------------------------------------------------------------------
POLAR_ACCESS_TOKEN=
POLAR_PRODUCT_ID=
POLAR_WEBHOOK_SECRET=
# sandbox | production
POLAR_SERVER=sandbox

# Optional: override the local webhook URL used by `npm run polar:listen`.
POLAR_FORWARD_URL=http://localhost:3000/api/webhooks/polar

# -----------------------------------------------------------------------------
# AI provider. Blank => mock text + procedurally generated illustrations.
# AI_PROVIDER selects the default; the app falls back to whichever key exists.
# -----------------------------------------------------------------------------
# openai | gemini
AI_PROVIDER=openai

# OpenAI (text + gpt-image-2)
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.1
OPENAI_IMAGE_MODEL=gpt-image-2

# Google Gemini (text + Nano Banana 2 = gemini-3.1-flash-image)
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image

# Generate the first image as the visual reference, then this many page images
# at a time. Keep low if your image provider rate-limits aggressively.
IMAGE_GENERATION_CONCURRENCY=2
